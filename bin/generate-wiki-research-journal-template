#!/usr/bin/python
import sys
import datetime

TEMPLATE = """# {date} {day}

"""

date = (datetime.date.today() if len(sys.argv) < 2
        # Expecting filename in <title>.foo format
        else datetime.date.fromisoformat(sys.argv[1].rsplit(".", 1)[0]))
print(TEMPLATE.format(date=date.strftime("%Y-%m-%d"), day=date.strftime("%A")))
